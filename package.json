{
  "name": "atscript-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run test -r && vp run build -r",
    "dev": "pnpm --filter vue-playground run dev",
    "demo:dev": "pnpm --filter @atscript/demo run dev",
    "docs:dev": "pnpm --filter docs run dev",
    "docs:build": "pnpm --filter docs run build",
    "build": "vp run build -r",
    "test": "vp run test -r",
    "release": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@atscript/db",
      "@atscript/db-client",
      "@atscript/db-sqlite",
      "@atscript/moost-db",
      "@swc/core",
      "better-sqlite3"
    ]
  }
}
