{
  "name": "@atscript/unocss-preset",
  "version": "0.0.1",
  "private": true,
  "description": "Shared UnoCSS plumbing for atscript-ui: Iconify-backed icons loader + vunor re-exports",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check"
  },
  "dependencies": {
    "@iconify/utils": "catalog:"
  },
  "devDependencies": {
    "@unocss/preset-icons": "catalog:",
    "unocss": "catalog:",
    "vunor": "catalog:"
  },
  "peerDependencies": {
    "@unocss/preset-icons": "catalog:",
    "unocss": "catalog:",
    "vunor": "catalog:"
  }
}
