{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": ["./src/*"],
      "@atscript/ui": ["../ui/src"],
      "@atscript/ui/*": ["../ui/src/*"],
      "@atscript/ui-fns": ["../ui-fns/src"],
      "@atscript/ui-fns/*": ["../ui-fns/src/*"],
      "@atscript/vue-form": ["../vue-form/src"],
      "@atscript/vue-form/*": ["../vue-form/src/*"],
      "@atscript/ui-table": ["../ui-table/src"],
      "@atscript/ui-table/*": ["../ui-table/src/*"],
      "@atscript/vue-table": ["../vue-table/src"],
      "@atscript/vue-table/*": ["../vue-table/src/*"],
      "@atscript/moost-wf": ["../moost-wf/src"],
      "@atscript/moost-wf/*": ["../moost-wf/src/*"],
      "@atscript/vue-wf": ["../vue-wf/src"],
      "@atscript/vue-wf/*": ["../vue-wf/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite-env.d.ts"]
}
