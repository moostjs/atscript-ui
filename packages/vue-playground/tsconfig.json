{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@atscript/ui-core": ["../ui-core/src"],
      "@atscript/ui-core/*": ["../ui-core/src/*"],
      "@atscript/ui-fns": ["../ui-fns/src"],
      "@atscript/ui-fns/*": ["../ui-fns/src/*"],
      "@atscript/vue-form": ["../vue-form/src"],
      "@atscript/vue-form/*": ["../vue-form/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts"]
}
