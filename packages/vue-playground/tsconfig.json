{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": ["./src/*"],
      "@atscript/ui": ["../ui/src"],
      "@atscript/ui/*": ["../ui/src/*"],
      "@atscript/ui-fns": ["../ui-fns/src"],
      "@atscript/ui-fns/*": ["../ui-fns/src/*"],
      "@atscript/vue-form": ["../vue-form/src"],
      "@atscript/vue-form/*": ["../vue-form/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts"]
}
