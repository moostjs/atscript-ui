{
  "name": "@atscript/vue-table",
  "version": "0.0.1",
  "description": "Type-driven table components for Atscript with Vue 3",
  "files": [
    "dist",
    "styles.d.ts"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": {
      "types": "./styles.d.ts",
      "default": "./dist/style.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@atscript/ui": "workspace:^",
    "@atscript/ui-table": "workspace:^"
  },
  "devDependencies": {
    "@atscript/db-client": "catalog:",
    "@atscript/typescript": "catalog:",
    "@tanstack/vue-virtual": "catalog:",
    "@uniqu/core": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/test-utils": "catalog:",
    "@vueuse/core": "catalog:",
    "happy-dom": "catalog:",
    "reka-ui": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "@atscript/db-client": "^0.1.45",
    "@tanstack/vue-virtual": "^3",
    "@vueuse/core": "^12",
    "reka-ui": "^2",
    "vue": "^3"
  }
}
