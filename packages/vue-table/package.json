{
  "name": "@atscript/vue-table",
  "version": "0.0.1",
  "description": "Type-driven table components for Atscript with Vue 3",
  "files": [
    "dist",
    "styles.d.ts"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./as-column-menu": {
      "types": "./dist/as-column-menu.d.mts",
      "import": "./dist/as-column-menu.mjs",
      "require": "./dist/as-column-menu.cjs"
    },
    "./as-config-dialog": {
      "types": "./dist/as-config-dialog.d.mts",
      "import": "./dist/as-config-dialog.mjs",
      "require": "./dist/as-config-dialog.cjs"
    },
    "./as-filter-dialog": {
      "types": "./dist/as-filter-dialog.d.mts",
      "import": "./dist/as-filter-dialog.mjs",
      "require": "./dist/as-filter-dialog.cjs"
    },
    "./as-filter-field": {
      "types": "./dist/as-filter-field.d.mts",
      "import": "./dist/as-filter-field.mjs",
      "require": "./dist/as-filter-field.cjs"
    },
    "./as-filter-input": {
      "types": "./dist/as-filter-input.d.mts",
      "import": "./dist/as-filter-input.mjs",
      "require": "./dist/as-filter-input.cjs"
    },
    "./as-filters": {
      "types": "./dist/as-filters.d.mts",
      "import": "./dist/as-filters.mjs",
      "require": "./dist/as-filters.cjs"
    },
    "./as-table": {
      "types": "./dist/as-table.d.mts",
      "import": "./dist/as-table.mjs",
      "require": "./dist/as-table.cjs"
    },
    "./as-table-cell-value": {
      "types": "./dist/as-table-cell-value.d.mts",
      "import": "./dist/as-table-cell-value.mjs",
      "require": "./dist/as-table-cell-value.cjs"
    },
    "./as-table-header-cell": {
      "types": "./dist/as-table-header-cell.d.mts",
      "import": "./dist/as-table-header-cell.mjs",
      "require": "./dist/as-table-header-cell.cjs"
    },
    "./as-table-root": {
      "types": "./dist/as-table-root.d.mts",
      "import": "./dist/as-table-root.mjs",
      "require": "./dist/as-table-root.cjs"
    },
    "./as-window-table": {
      "types": "./dist/as-window-table.d.mts",
      "import": "./dist/as-window-table.mjs",
      "require": "./dist/as-window-table.cjs"
    },
    "./styles": {
      "types": "./styles.d.ts",
      "default": "./dist/style.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/gen-exports.mjs && vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@atscript/ui": "workspace:^",
    "@atscript/ui-table": "workspace:^"
  },
  "devDependencies": {
    "@atscript/db-client": "catalog:",
    "@atscript/typescript": "catalog:",
    "@tanstack/vue-virtual": "catalog:",
    "@uniqu/core": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/test-utils": "catalog:",
    "@vueuse/core": "catalog:",
    "happy-dom": "catalog:",
    "reka-ui": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:",
    "vunor": "catalog:"
  },
  "peerDependencies": {
    "@atscript/db-client": "^0.1.45",
    "@tanstack/vue-virtual": "^3",
    "@vueuse/core": "^12",
    "reka-ui": "^2",
    "vue": "^3"
  }
}
