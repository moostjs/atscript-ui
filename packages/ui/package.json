{
  "name": "@atscript/ui",
  "version": "0.0.1",
  "description": "Framework-agnostic runtime for form and table definitions from atscript annotated types",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.mts",
      "import": "./dist/plugin.mjs",
      "require": "./dist/plugin.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "devDependencies": {
    "@atscript/core": "catalog:",
    "@atscript/typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@atscript/core": "^0.1.45",
    "@atscript/typescript": "^0.1.45"
  }
}
