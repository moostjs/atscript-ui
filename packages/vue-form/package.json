{
  "name": "@atscript/vue-form",
  "version": "0.0.1",
  "description": "Type-driven form rendering for Atscript with Vue 3",
  "files": [
    "dist",
    "styles.d.ts"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./unocss": {
      "types": "./dist/unocss/index.d.mts",
      "import": "./dist/unocss/index.mjs",
      "require": "./dist/unocss/index.cjs"
    },
    "./styles": {
      "types": "./styles.d.ts",
      "default": "./dist/style.css"
    },
    "./unocss.css": "./dist/unocss.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack && unocss 'src/**/*.{vue,ts}' -o dist/unocss.css --minify",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@atscript/ui": "workspace:^"
  },
  "devDependencies": {
    "@atscript/core": "catalog:",
    "@atscript/db-client": "catalog:",
    "@atscript/typescript": "catalog:",
    "@atscript/ui-fns": "workspace:^",
    "@atscript/unocss-preset": "workspace:^",
    "@tsdown/css": "catalog:",
    "@unocss/cli": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/test-utils": "catalog:",
    "happy-dom": "catalog:",
    "reka-ui": "catalog:",
    "unocss": "catalog:",
    "unplugin-atscript": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:",
    "vunor": "catalog:"
  },
  "peerDependencies": {
    "@atscript/db-client": "^0.1",
    "@atscript/ui-fns": "^0.0.1",
    "reka-ui": "^2",
    "vue": "^3"
  }
}
