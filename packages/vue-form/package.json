{
  "name": "@atscript/vue-form",
  "version": "0.0.1",
  "description": "Type-driven form rendering for Atscript with Vue 3",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@atscript/ui-core": "workspace:^"
  },
  "devDependencies": {
    "@atscript/typescript": "catalog:",
    "@atscript/ui-fns": "workspace:^",
    "@tsdown/css": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "@atscript/ui-fns": "^0.0.1",
    "vue": "^3"
  }
}
